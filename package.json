{
  "name": "sejong-auth",
  "version": "0.1.0",
  "description": "Sejong University portal authentication and academic data fetching",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "sejong-auth-server": "./dist/server/app.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server/app.ts",
    "start": "node dist/server/app.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration/"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "axios-cookiejar-support": "^4.0.0",
    "express": "^4.21.0",
    "tough-cookie": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/tough-cookie": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
